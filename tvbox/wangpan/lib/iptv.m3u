<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    
    <!-- Link to external CSS -->
    <link rel="stylesheet" href="static/css/umi.f7cf03d0.css">
    

    
    <!-- Meta tags for SEO -->
    <title data-rh="true">GitHub文件代理加速</title>
    <meta data-rh="true" property="og:title" content="GitHub文件代理加速">
    <meta data-rh="true" name="description" content="GitHub 文件 , Releases , archive , gist , raw.githubusercontent.com 文件代理加速下载服务。">
    <meta data-rh="true" property="og:description" content="GitHub 文件 , Releases , archive , gist , raw.githubusercontent.com 文件代理加速下载服务。">
    
    <!-- Canonical Link -->
    <link data-rh="true" rel="canonical" href="https://wget.la">
</head>

<body>
    <!-- NoScript message -->
    <noscript><b>Enable JavaScript to run this app.</b></noscript>
    
    <!-- Root div for React app -->
    <div id="root">
        <!-- Some template structure for React -->
        <template id="B:0"></template>
        <div></div>
    </div>

    <!-- UMI loader script -->
    <script>window.__UMI_LOADER_DATA__ = {}</script>
    <script async src="static/js/umi.762db907.js"></script>

    
    <!-- React rendering logic -->
    <script>
        function $RC(a, b) {
            a = document.getElementById(a);
            b = document.getElementById(b);
            b.parentNode.removeChild(b);
            if (a) {
                a = a.previousSibling;
                var f = a.parentNode, c = a.nextSibling, e = 0;
                do {
                    if (c && 8 === c.nodeType) {
                        var d = c.data;
                        if ("/$" === d) {
                            if (0 === e) break;
                            else e--;
                        } else if ("$" !== d && "$?" !== d && "$!" !== d) e++;
                    }
                    d = c.nextSibling;
                    f.removeChild(c);
                    c = d;
                } while (c);
                for (; b.firstChild;) f.insertBefore(b.firstChild, c);
                a.data = "$";
                a._reactRetry && a._reactRetry();
            }
        }
        $RC("B:0", "S:0");
    </script>

</body>
</html>
